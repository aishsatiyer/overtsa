{
  "manifest_version": 3,
  "name": "Overtly GTM Helper",
  "version": "0.1.0",
  "description": "Active-page LinkedIn capture helper for Overtly.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["storage", "tabs", "sidePanel"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:4000/*",
    "https://logo.clearbit.com/*",
    "https://img.logo.dev/*",
    "https://www.google.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Overtly GTM Helper",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_popup": "popup.html"
  }
}
